# Environment variables for the Text Vectorization Agent
# Copy this file to .env and customize as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Model Configuration
DEFAULT_MODEL_PATH=artifacts/vectors.model
DEFAULT_VECTOR_SIZE=300
DEFAULT_WINDOW_SIZE=5
DEFAULT_MIN_COUNT=5
DEFAULT_EPOCHS=10

# spaCy Configuration
SPACY_MODEL=en_core_web_sm

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Redis Configuration (for future message queue implementation)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Cloud Configuration (for future deployment)
AZURE_STORAGE_CONNECTION_STRING=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
